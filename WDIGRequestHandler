def _json(self, status, data):
    body = json.dumps(data).encode("utf-8")
    self.send_response(status)
    self.send_header("Content-Type", "application/json")
    self.send_header("Content-Length", str(len(body)))
    self.end_headers()
    self.wfile.write(body)

def do_GET(self):
    if self.path == "/status":
        token = load_license_token()

        self._json(200, {
            "node": "WDIG Surface OS",
            "mode": "full" if token else "trial",
            "licensed": bool(token),
            "license_token_present": bool(token)
        })
        return

    if self.path.startswith("/activate"):
        node_id = "wdig-node-local"

        checkout_url = (
            f"{CYBERCROWD_API}/create-license-checkout"
            f"?node_id={urllib.parse.quote(node_id)}"
        )

        self.send_response(302)
        self.send_header("Location", checkout_url)
        self.end_headers()
        return

    if self.path.startswith("/claim-license"):
        query = urllib.parse.urlparse(self.path).query
        params = urllib.parse.parse_qs(query)
        session_id = params.get("session_id", [None])[0]

        if not session_id:
            self._json(400, {"error": "missing_session_id"})
            return

        claim_url = f"{CYBERCROWD_API}/claim-license?session_id={urllib.parse.quote(session_id)}"

        try:
            with urllib.request.urlopen(claim_url, timeout=10) as response:
                data = json.loads(response.read().decode("utf-8"))

            if data.get("license_token"):
                save_license_token(data["license_token"])
                self._json(200, {
                    "status": "activated",
                    "mode": "full"
                })
            else:
                self._json(400, {
                    "status": "not_activated",
                    "error": data
                })

        except Exception as e:
            self._json(500, {
                "error": "claim_failed",
                "detail": str(e)
            })

        return
